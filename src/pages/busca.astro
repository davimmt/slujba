---
import "../styles/global.css";
import troparios from "../data/troparios.json";
import kontakia from "../data/kondakions.json";

const items = [
  ...Object.entries(troparios).map(([id, item]) => ({
    id,
    tipo: "Tropário",
    ...item,
  })),
  ...Object.entries(kontakia).map(([id, item]) => ({
    id,
    tipo: "Kondákion",
    ...item,
  })),
];
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/slujba/favicon.jpg" />
    <title>Slujba - Busca</title>
  </head>

  <body>
    <header class="header print:hidden">
      <div class="max-w-3xl mx-auto px-6 py-3 text-[11px]">
        <a class="
          select-none outline-none
          text-red-500 hover:text-amber-500 transition
          " href="/slujba/"><span style="display:inline-block; transform:scaleX(-1);">➜</span> Voltar ao Início</a>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-5">
      <h1 class="text-lg font-bold">Tropários e Kondákios</h1>

      <input id="search" type="search" placeholder="Pesquisar por título, tom ou texto..."
      class="
         w-full max-w-md mt-3 px-5 py-1 print:hidden
         rounded-md border border-amber-600/30 bg-[rgb(30,19,11)] text-amber-100
         placeholder:text-amber-600/20 placeholder:text-sm outline-none
         focus:border-red-400/50 focus:ring-1 focus:ring-red-400/20 transition
        "
      />

      <p id="count" class="text-(--detail) text-[12px] mt-1 mb-7"></p>
      <div id="results"></div>
      <div class="flex gap-3 items-center mt-4 text-xs">
        <button id="prev" class="
          rounded-md
          border
          border-amber-600/25
          bg-transparent
          px-4
          py-2
          text-amber-300
          transition
          hover:border-red-400/40
          hover:text-red-500
          disabled:opacity-40
          disabled:pointer-events-none
          select-none
          outline-none
          focus:outline-none
          focus:ring-0
          active:outline-none
          cursor-pointer
        ">Anterior</button>
        <span id="pageInfo"></span>
        <button id="next" class="
          rounded-md
          border
          border-amber-600/25
          bg-transparent
          px-4
          py-2
          text-amber-300
          transition
          hover:border-red-400/40
          hover:text-red-500
          disabled:opacity-40
          disabled:pointer-events-none
          select-none
              outline-none
              focus:outline-none
              focus:ring-0
              active:outline-none
              cursor-pointer
        ">Próxima</button>
      </div>
    </main>

    <script type="module" define:vars={{ items }}>
      const PAGE_SIZE = 8;

      const search = document.getElementById("search");
      const results = document.getElementById("results");
      const count = document.getElementById("count");
      const pageInfo = document.getElementById("pageInfo");
      const prev = document.getElementById("prev");
      const next = document.getElementById("next");

      function getParams() {
        const url = new URL(window.location.href);

        return {
          q: url.searchParams.get("q") || "",
          page: parseInt(url.searchParams.get("page") || "1", 10),
        };
      }

      function setParams(q, page) {
        const url = new URL(window.location.href);

        if (q) url.searchParams.set("q", q);
        else url.searchParams.delete("q");

        url.searchParams.set("page", page);

        window.history.replaceState({}, "", url);
      }

      const params = getParams();

      let query = params.q;
      let page = params.page;
      let filtered = items;

      search.value = query;

      function normalize(str) {
        return (str || "")
          .toString()
          .normalize("NFKD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase();
      }

      function highlight(text, q) {
        if (!q) return text;

        const normText = normalize(text);
        const normQuery = normalize(q);

        let result = "";
        let i = 0;
        let j = 0;

        while (i < text.length) {
          const slice = text.slice(i, i + 1);
          const normSlice = normalize(slice);

          if (normText.slice(j, j + normQuery.length) === normQuery) {
            result += `<mark>${text.slice(i, i + normQuery.length)}</mark>`;
            i += normQuery.length;
            j += normQuery.length;
            continue;
          }

          result += text[i];
          i++;
          j++;
        }

        return result;
      }

      function syncURL() {
        setParams(query, page);
      }

      function applyFilter() {
        const q = normalize(query);

        filtered = items.filter((item) => {
          const text = normalize(
            item.titulo + " " + item.versos + " " + item.tom + " " + item.tipo
          );

          return text.includes(q);
        });

        page = 1;
        syncURL();
        render();
      }

      function render() {
        const totalPages = Math.max(
          1,
          Math.ceil(filtered.length / PAGE_SIZE)
        );

        if (page > totalPages) page = totalPages;

        const start = (page - 1) * PAGE_SIZE;

        const pageItems = filtered.slice(start, start + PAGE_SIZE);

        results.innerHTML = pageItems
          .map(
            (item) => `
              <article class="
                group
                my-5
                rounded-lg
                border border-amber-500/20
                bg-amber-950/10
                p-6
                transition-colors
                hover:border-amber-400/40
                hover:bg-amber-950/20
              ">
                <header class="mb-4">
                  <p class="mb-2 text-[11px] uppercase tracking-[.22em] text-amber-500/60">
                    ${highlight(item.tipo, query)} — Tom ${item.tom}
                  </p>

                  <h2 class="text-[1.2rem] tracking-tight text-red-300/90 leading-snug">
                    ${highlight(item.titulo, query)}
                  </h2>
                </header>

                <div class="my-4 h-px w-10 bg-amber-500/30"></div>

                <p class="leading-9 text-[1.02rem]text-amber-100/90">
                  ${highlight(item.versos, query)}
                </p>
              </article>
            `
          )
          .join("");

        count.textContent = `${filtered.length} resultado(s)`;
        pageInfo.textContent = `Página ${page} de ${totalPages}`;

        prev.disabled = page <= 1;
        next.disabled = page >= totalPages;
      }

      search.addEventListener("input", (e) => {
        query = e.target.value;
        applyFilter();
      });

      prev.addEventListener("click", () => {
        if (page > 1) {
          page--;
          syncURL();
          render();
        }
      });

      next.addEventListener("click", () => {
        const totalPages = Math.ceil(filtered.length / PAGE_SIZE);

        if (page < totalPages) {
          page++;
          syncURL();
          render();
        }
      });

      applyFilter();
    </script>
  </body>
</html>
